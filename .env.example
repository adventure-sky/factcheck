# 假訊息情報中心 環境變數設定範例
# 複製此檔案為 .env，填入實際的 API key

# Google Gemini API（從 Google AI Studio 取得：aistudio.google.com）
GEMINI_API_KEY=your-gemini-api-key-here

# Google Fact Check API
GOOGLE_FACT_CHECK_API_KEY=your-google-api-key-here

# ChromaDB 路徑（預設本地，Zeabur 部署時改為掛載的 Volume 路徑）
CHROMA_DB_PATH=./chroma_db

# 應用設定
APP_ENV=development
APP_PORT=8000
